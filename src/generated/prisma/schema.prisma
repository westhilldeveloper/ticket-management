generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String          @id @default(uuid())
  email               String          @unique
  password            String?
  name                String
  branch              String?
  role                Role            @default(EMPLOYEE)
  department          String?
  isActive            Boolean         @default(true)
  emailVerified       Boolean         @default(false)
  otp                 String?
  otpExpiry           DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  auditLogs           AuditLog[]
  headedDepartment    Department?     @relation("DepartmentHead")
  notifications       Notification[]
  reviews             Review[]
  historyEntries      TicketHistory[]
  assignedTickets     Ticket[]        @relation("AssignedTickets")
  createdTickets      Ticket[]        @relation("UserTickets")
  memberOfDepartments Department[]    @relation("DepartmentMembers")

  @@map("users")
}

model Ticket {
  id                 String              @id @default(uuid())
  ticketNumber       String              @unique
  title              String
  description        String?
  mainCategoryId     String?
  mainCategory       DynamicCategory?    @relation(fields: [mainCategoryId], references: [id])
  requestServiceType RequestServiceType?
  itemType           String?
  serviceDetails     Json?
  count              String?
  category           String
  priority           Priority            @default(MEDIUM)
  status             Status              @default(OPEN)
  attachment         String?
  attachmentPublicId String?
  serialNumber       String?
  createdById        String
  assignedToId       String?
  mdApproval         MDFeedback?         @default(PENDING)
  mdApprovedAt       DateTime?
  mdRejectedAt       DateTime?
  mdRejectReason     String?
  mdApprovalComment  String?
  thirdParty         Boolean             @default(false)
  thirdPartyStatus   String?
  thirdPartyDetails  String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  closedAt           DateTime?
  notifications      Notification[]
  reviews            Review[]
  history            TicketHistory[]
  assignedTo         User?               @relation("AssignedTickets", fields: [assignedToId], references: [id])
  createdBy          User                @relation("UserTickets", fields: [createdById], references: [id])

  @@index([createdById])
  @@index([assignedToId])
  @@index([status])
  @@index([category])
  @@index([ticketNumber])
  @@map("tickets")
}

model Review {
  id          String     @id @default(uuid())
  content     String
  reviewType  ReviewType
  createdById String
  ticketId    String
  createdAt   DateTime   @default(now())
  createdBy   User       @relation(fields: [createdById], references: [id])
  ticket      Ticket     @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
  @@index([createdById])
  @@map("reviews")
}

model TicketHistory {
  id          String   @id @default(uuid())
  action      String
  description String?
  oldValue    String?
  newValue    String?
  createdById String
  ticketId    String
  createdAt   DateTime @default(now())
  createdBy   User     @relation(fields: [createdById], references: [id])
  ticket      Ticket   @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
  @@index([createdById])
  @@index([createdAt])
  @@map("ticket_history")
}

model Notification {
  id          String           @id @default(uuid())
  type        NotificationType
  title       String
  message     String
  userId      String
  ticketId    String?
  read        Boolean          @default(false)
  readAt      DateTime?
  emailSent   Boolean          @default(false)
  emailSentAt DateTime?
  createdAt   DateTime         @default(now())
  ticket      Ticket?          @relation(fields: [ticketId], references: [id])
  user        User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  headId      String?  @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  head        User?    @relation("DepartmentHead", fields: [headId], references: [id])
  members     User[]   @relation("DepartmentMembers")

  @@map("departments")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  category    String   @default("general")
  isPublic    Boolean  @default(false)
  updatedBy   String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  entityType String
  entityId   String?
  userId     String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

model ItemCategory {
  id          String     @id @default(uuid())
  name        String     @unique // "IT", "ADMIN", "HR"
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  items       ItemType[]

  @@map("item_categories")
}

model ItemType {
  id         String             @id @default(uuid())
  name       String // e.g., "Laptop", "Repair", "Leave Application"
  categoryId String // references ItemCategory
  type       RequestServiceType // REQUEST or SERVICE
  isActive   Boolean            @default(true)
  sortOrder  Int                @default(0)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  category ItemCategory @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, name, type])
  @@map("item_types")
}

enum Role {
  EMPLOYEE
  ADMIN
  MD
  SERVICE_TEAM
  SUPER_ADMIN

  @@map("roles")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("priorities")
}

enum Status {
  OPEN
  PENDING_MD_APPROVAL
  PENDING_THIRD_PARTY
  IN_PROGRESS
  APPROVED_BY_MD
  REJECTED_BY_MD
  PENDING_SERVICE_ACCEPTANCE
  SERVICE_IN_PROGRESS
  REJECTED_BY_SERVICE
  SERVICE_RESOLVED
  RESOLVED
  CLOSED

  @@map("statuses")
}

enum ReviewType {
  TICKET_CREATION
  ADMIN_REVIEW
  MD_REVIEW
  STATUS_UPDATE
  SYSTEM_NOTE

  @@map("review_types")
}

enum MDFeedback {
  PENDING
  APPROVED
  REJECTED

  @@map("md_feedback")
}

enum NotificationType {
  TICKET_CREATED
  TICKET_UPDATED
  TICKET_ASSIGNED
  MD_APPROVAL_REQUIRED
  MD_APPROVED
  MD_REJECTED
  REVIEW_ADDED
  STATUS_CHANGED
  THIRD_PARTY_UPDATE

  @@map("notification_types")
}

model DynamicCategory {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., "IT", "HR", "FINANCE"
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets Ticket[] // tickets that use this category

  @@map("dynamic_categories")
}

enum RequestServiceType {
  REQUEST
  SERVICE
}
